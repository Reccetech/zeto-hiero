{
  "name": "zeto-hiero",
  "version": "0.1.0",
  "private": true,
  "description": "Zeto privacy pool for Hedera Smart Contract Service. Hyperledger Labs Zeto + Hedera-specific contracts, SDK, and tooling.",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "test:size": "hardhat-contract-sizer",
    "deploy:testnet": "hardhat deploy --network hedera_testnet",
    "deploy:local": "hardhat deploy --network hardhat",
    "check:connection": "hardhat run scripts/check-connection.ts --network hedera_testnet",
    "lint": "echo 'lint not configured yet'"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.0.2",
    "@openzeppelin/hardhat-upgrades": "^3.5.0",
    "@types/node": "^20.11.0",
    "circomlibjs": "^0.1.7",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.10",
    "hardhat-contract-sizer": "^2.10.0",
    "hardhat-deploy": "^0.12.4",
    "snarkjs": "^0.7.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  }
}
